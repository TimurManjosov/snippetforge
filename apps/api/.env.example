# ============================================
# NESTJS API CONFIGURATION
# ============================================

PORT=3001
NODE_ENV=development
API_VERSION=0.1.0

# ============================================
# DATABASE
# ============================================

DATABASE_URL=postgresql://snippetforge:dev_password@localhost:5432/snippetforge

# ============================================
# AUTH
# ============================================

JWT_SECRET=change-me-to-a-secret-with-at-least-32-characters
JWT_EXPIRES_IN=15m

# ============================================
# CORS / DOCS
# ============================================

CORS_ORIGIN=http://localhost:3000
ENABLE_SWAGGER=true

# ============================================
# METRICS
# ============================================

METRICS_ENABLED=false
# Optional: when set, /metrics requires Authorization: Bearer <token>
METRICS_TOKEN=

# ============================================
# SENTRY (optional)
# ============================================

SENTRY_DSN_API=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
