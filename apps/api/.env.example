# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string.
# Docker Compose default: postgres://snippetforge:dev_password@localhost:5432/snippetforge
DATABASE_URL=postgres://snippetforge:dev_password@localhost:5432/snippetforge

# ============================================
# AUTHENTICATION
# ============================================
# Secret key used to sign JWT tokens. Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# IMPORTANT: the API refuses to start in production (NODE_ENV=production) if this
# value is missing, empty, or left as the placeholder below.
JWT_SECRET=change_me_in_production

# Token expiry. Supported units: s (seconds), m (minutes), h (hours), d (days).
# Example: 15m, 1h, 7d
JWT_EXPIRES_IN=15m

# ============================================
# SERVER
# ============================================
# Port the API listens on.
PORT=3001

# Allowed CORS origin (Next.js frontend URL).
CORS_ORIGIN=http://localhost:3000

# ============================================
# SWAGGER / API DOCS
# ============================================
# Set to false to disable Swagger UI in production.
ENABLE_SWAGGER=true

# ============================================
# SENTRY ERROR TRACKING (optional)
# ============================================
# DSN from https://sentry.io — leave empty to disable error reporting.
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=development
# Set to git SHA in CI: SENTRY_RELEASE=${GITHUB_SHA}
SENTRY_RELEASE=
# 0 = disabled, 1.0 = 100% (expensive in production)
SENTRY_TRACES_SAMPLE_RATE=0

# ============================================
# NODE
# ============================================
NODE_ENV=development
