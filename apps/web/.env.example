# ============================================
# NEXT.JS CONFIGURATION
# ============================================

# Public API URL (accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ============================================
# ENVIRONMENT
# ============================================

# Node environment
NODE_ENV=development

# ─── Sentry Error Tracking ─────────────────────────────────────────────────
# API
SENTRY_DSN_API=               # Required for API error tracking
SENTRY_ENVIRONMENT=production # development | staging | production
SENTRY_RELEASE=               # Set to git SHA in CI: SENTRY_RELEASE=${GITHUB_SHA}
SENTRY_TRACES_SAMPLE_RATE=0   # 0 = disabled, 1.0 = 100% (expensive)

# Web (Server-Side)
SENTRY_DSN_WEB=               # Required for SSR error tracking

# Web (Client-Side – must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Analytics (future)
# NEXT_PUBLIC_GA_ID=
